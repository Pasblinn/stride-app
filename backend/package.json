{
  "name": "stride-app-backend",
  "version": "1.0.0",
  "description": "Aplicativo para a disciplina de dispositivos móveis",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
  "build": "tsc",
  "start": "node dist/app/server.js",
  "dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register -r dotenv/config\" src/app/server.ts",
  "typeorm": "ts-node -r tsconfig-paths/register -r dotenv/config ./node_modules/typeorm/cli.js",
  "migration:create": "npm run typeorm -- migration:create src/db/typeorm/migrations/",
  "migration:generate": "npm run typeorm -- migration:generate -d src/db/typeorm/data-source.ts src/db/typeorm/migrations/",
  "migration:run": "npm run typeorm -- migration:run -d src/db/typeorm/data-source.ts",
  "migration:revert": "npm run typeorm -- migration:revert -d src/db/typeorm/data-source.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/jsonwebtoken": "^9.0.10",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
